#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUILD_DIR="$(mktemp -d)"
trap 'rm -rf "$BUILD_DIR"' EXIT

cd "$ROOT_DIR"
bundle exec jekyll build --destination "$BUILD_DIR" >/dev/null
cp "$BUILD_DIR/codelabs/index.html" "$ROOT_DIR/codelabs/index.html"
echo "Updated codelabs/index.html from Jekyll build output."

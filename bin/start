#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PID_FILE="$ROOT_DIR/.jekyll-server.pid"
LOG_FILE="$ROOT_DIR/.jekyll-server.log"
HOST="${HOST:-127.0.0.1}"
PORT="${PORT:-4000}"
BUNDLE_PATH="${PERSONAL_BLOG_BUNDLE_PATH:-/tmp/personal-blog-bundle}"

cd "$ROOT_DIR"

if [[ -f "$PID_FILE" ]]; then
  existing_pid="$(cat "$PID_FILE")"
  if kill -0 "$existing_pid" 2>/dev/null; then
    echo "Jekyll is already running at http://$HOST:$PORT/ (pid $existing_pid)."
    exit 0
  fi
  rm -f "$PID_FILE"
fi

if lsof -nP -iTCP:"$PORT" -sTCP:LISTEN >/dev/null 2>&1; then
  echo "Port $PORT is already in use. Run ./bin/stop or set PORT=another_port."
  lsof -nP -iTCP:"$PORT" -sTCP:LISTEN
  exit 1
fi

if ! BUNDLE_PATH="$BUNDLE_PATH" bundle check >/dev/null 2>&1; then
  echo "Installing missing gems into $BUNDLE_PATH..."
  BUNDLE_PATH="$BUNDLE_PATH" bundle install
fi

echo "Starting Jekyll at http://$HOST:$PORT/ ..."
BUNDLE_PATH="$BUNDLE_PATH" bundle exec jekyll serve --host "$HOST" --port "$PORT" >"$LOG_FILE" 2>&1 &
server_pid="$!"
echo "$server_pid" > "$PID_FILE"

sleep 2

if ! kill -0 "$server_pid" 2>/dev/null; then
  echo "Jekyll failed to start. Last log lines:"
  tail -n 40 "$LOG_FILE"
  rm -f "$PID_FILE"
  exit 1
fi

echo "Jekyll is running at http://$HOST:$PORT/ (pid $server_pid)."
echo "Logs: $LOG_FILE"
